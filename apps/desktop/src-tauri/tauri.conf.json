{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "git-fried",
  "version": "0.0.0",
  "identifier": "io.gitfried.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "git-fried",
        "label": "main",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "fullscreen": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://api.github.com https://*"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "category": "DeveloperTool",
    "shortDescription": "Git-fried — GitKraken alternative desktop client",
    "longDescription": "Gitea-first, Korean-safe, Tauri-light desktop git client for managing GitHub personal repos and Gitea company repos side-by-side.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "ko-KR"
      },
      "nsis": {
        "languages": ["Korean", "English"]
      }
    }
  }
}
