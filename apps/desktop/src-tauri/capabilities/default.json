{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability — git-fried desktop default",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "deep-link:default",
    "deep-link:allow-get-current",
    "dialog:default",
    "dialog:allow-open",
    "fs:default",
    "notification:default",
    "shell:allow-open"
  ]
}
