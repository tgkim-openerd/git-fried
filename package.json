{
  "name": "git-fried",
  "version": "0.3.0",
  "private": true,
  "description": "GitKraken alternative desktop git client. Gitea first-class, Korean-safe, Tauri-light, multi-repo native.",
  "license": "MIT",
  "author": "tgkim",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "bun run --cwd apps/desktop dev",
    "dev:cleanup": "node scripts/dev-cleanup.mjs",
    "build": "bun run --cwd apps/desktop build",
    "tauri": "node scripts/tauri-rustup.mjs",
    "tauri:dev": "node scripts/tauri-rustup.mjs dev",
    "tauri:build": "node scripts/tauri-rustup.mjs build",
    "tauri:dev:raw": "bun run --cwd apps/desktop tauri dev",
    "test": "bun run --cwd apps/desktop test && bun run test:rust",
    "test:rust": "node scripts/cargo-rustup.mjs test --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "test:web": "bun run --cwd apps/desktop test",
    "check:rust": "node scripts/cargo-rustup.mjs check --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "lint": "bun run --cwd apps/desktop lint",
    "typecheck": "bun run --cwd apps/desktop typecheck",
    "fmt": "bun run --cwd apps/desktop fmt && node scripts/cargo-rustup.mjs fmt --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "test:e2e": "playwright test",
    "test:e2e:tauri": "playwright test --config playwright.tauri.config.ts",
    "i18n:count": "node scripts/i18n-leaf-count.mjs"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "packageManager": "bun@1.1.0",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "lefthook": "^2.1.6",
    "playwright": "^1.59.1"
  }
}
